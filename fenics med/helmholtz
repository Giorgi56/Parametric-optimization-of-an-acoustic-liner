import numpy as np
import matplotlib.pyplot as plt
import matplotlib.tri as mtri
import ufl

from mpi4py import MPI
from dolfinx import mesh, fem, default_scalar_type
from dolfinx.fem.petsc import LinearProblem
from basix.ufl import element, mixed_element


# ============================================================
# Paramètre
# ============================================================
k = 8.0


# ============================================================
# Maillage du carré [0,1]x[0,1]
# ============================================================
domain = mesh.create_unit_square(MPI.COMM_WORLD, 80, 80)
tdim = domain.topology.dim
fdim = tdim - 1


# ============================================================
# Bords
# ============================================================
def left(x):
    return np.isclose(x[0], 0.0)

def right(x):
    return np.isclose(x[0], 1.0)

def bottom(x):
    return np.isclose(x[1], 0.0)

def top(x):
    return np.isclose(x[1], 1.0)


facets_left = mesh.locate_entities_boundary(domain, fdim, left)
facets_right = mesh.locate_entities_boundary(domain, fdim, right)
facets_bottom = mesh.locate_entities_boundary(domain, fdim, bottom)
facets_top = mesh.locate_entities_boundary(domain, fdim, top)

facet_indices = np.hstack([facets_left, facets_right, facets_bottom, facets_top]).astype(np.int32)
facet_markers = np.hstack([
    np.full(len(facets_left), 1, dtype=np.int32),
    np.full(len(facets_right), 2, dtype=np.int32),
    np.full(len(facets_bottom), 3, dtype=np.int32),
    np.full(len(facets_top), 4, dtype=np.int32),
])

perm = np.argsort(facet_indices)
facet_tag = mesh.meshtags(domain, fdim, facet_indices[perm], facet_markers[perm])

dx = ufl.dx(domain)
ds = ufl.Measure("ds", domain=domain, subdomain_data=facet_tag)


# ============================================================
# Espace mixte : u = ur + i ui
# ============================================================
P1 = element("Lagrange", domain.basix_cell(), 1)
W = fem.functionspace(domain, mixed_element([P1, P1]))


# ============================================================
# Inconnues et tests
# ============================================================
(ur, ui) = ufl.TrialFunctions(W)
(vr, vi) = ufl.TestFunctions(W)


# ============================================================
# Formulation faible
#
# u = ur + i ui
# sur Gamma_R : ∂n u + i k u = 0
#
# ce qui donne :
# Re : ∫ grad(ur).grad(vr) - k² ur vr  - k ui vr ds(R)
# Im : ∫ grad(ui).grad(vi) - k² ui vi  + k ur vi ds(R)
# ============================================================
a = (
    ufl.inner(ufl.grad(ur), ufl.grad(vr)) * dx
    - (k**2) * ur * vr * dx
    - k * ui * vr * ds(2)
    + ufl.inner(ufl.grad(ui), ufl.grad(vi)) * dx
    - (k**2) * ui * vi * dx
    + k * ur * vi * ds(2)
)

L = fem.Constant(domain, default_scalar_type(0.0)) * (vr + vi) * dx


# ============================================================
# Conditions de Dirichlet à gauche :
# ur = 1, ui = 0
# ============================================================
dofs_r = fem.locate_dofs_topological(W.sub(0), fdim, facets_left)
dofs_i = fem.locate_dofs_topological(W.sub(1), fdim, facets_left)

bc_r = fem.dirichletbc(default_scalar_type(1.0), dofs_r, W.sub(0))
bc_i = fem.dirichletbc(default_scalar_type(0.0), dofs_i, W.sub(1))

bcs = [bc_r, bc_i]


# ============================================================
# Résolution
# ============================================================
problem = LinearProblem(
    a,
    L,
    bcs=bcs,
    petsc_options_prefix="helmholtz",
    petsc_options={
        "ksp_type": "preonly",
        "pc_type": "lu"
    }
)

uh = problem.solve()


# ============================================================
# Extraction de ur et ui
# ============================================================
V0, map_r = W.sub(0).collapse()
V1, map_i = W.sub(1).collapse()

ur_h = fem.Function(V0)
ui_h = fem.Function(V1)

ur_h.x.array[:] = uh.x.array[map_r]
ui_h.x.array[:] = uh.x.array[map_i]


# ============================================================
# Préparation de la visualisation
# ============================================================
if MPI.COMM_WORLD.rank == 0:
    coords = V0.tabulate_dof_coordinates()[:, :2]

    domain.topology.create_connectivity(tdim, 0)
    cells = domain.topology.connectivity(tdim, 0).array.reshape((-1, 3))

    triang = mtri.Triangulation(coords[:, 0], coords[:, 1], cells)

    ur_vals = ur_h.x.array
    ui_vals = ui_h.x.array
    uabs_vals = np.sqrt(ur_vals**2 + ui_vals**2)

    # ============================
    # Visualisation 2D
    # ============================
    fig2d, axes = plt.subplots(1, 3, figsize=(16, 4.8))

    c0 = axes[0].tricontourf(triang, ur_vals, levels=50)
    axes[0].set_title("Re(u)")
    axes[0].set_xlabel("x")
    axes[0].set_ylabel("y")
    axes[0].set_aspect("equal")
    plt.colorbar(c0, ax=axes[0])

    c1 = axes[1].tricontourf(triang, ui_vals, levels=50)
    axes[1].set_title("Im(u)")
    axes[1].set_xlabel("x")
    axes[1].set_ylabel("y")
    axes[1].set_aspect("equal")
    plt.colorbar(c1, ax=axes[1])

    c2 = axes[2].tricontourf(triang, uabs_vals, levels=50)
    axes[2].set_title("|u|")
    axes[2].set_xlabel("x")
    axes[2].set_ylabel("y")
    axes[2].set_aspect("equal")
    plt.colorbar(c2, ax=axes[2])

    plt.tight_layout()

    # ============================
    # Visualisation 3D
    # ============================
    fig3d = plt.figure(figsize=(18, 5))

    ax1 = fig3d.add_subplot(131, projection="3d")
    s1 = ax1.plot_trisurf(coords[:, 0], coords[:, 1], ur_vals,
                          triangles=cells, cmap="viridis", linewidth=0.1)
    ax1.set_title("Surface 3D Re(u)")
    ax1.set_xlabel("x")
    ax1.set_ylabel("y")
    ax1.set_zlabel("Re(u)")
    fig3d.colorbar(s1, ax=ax1, shrink=0.6)

    ax2 = fig3d.add_subplot(132, projection="3d")
    s2 = ax2.plot_trisurf(coords[:, 0], coords[:, 1], ui_vals,
                          triangles=cells, cmap="plasma", linewidth=0.1)
    ax2.set_title("Surface 3D Im(u)")
    ax2.set_xlabel("x")
    ax2.set_ylabel("y")
    ax2.set_zlabel("Im(u)")
    fig3d.colorbar(s2, ax=ax2, shrink=0.6)

    ax3 = fig3d.add_subplot(133, projection="3d")
    s3 = ax3.plot_trisurf(coords[:, 0], coords[:, 1], uabs_vals,
                          triangles=cells, cmap="inferno", linewidth=0.1)
    ax3.set_title("Surface 3D |u|")
    ax3.set_xlabel("x")
    ax3.set_ylabel("y")
    ax3.set_zlabel("|u|")
    fig3d.colorbar(s3, ax=ax3, shrink=0.6)

    plt.tight_layout()
    plt.show()